ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
LLM_TIMEOUT_MS=120000
LLM_PROVIDER=openai

# Official Etsy Open API v3 credentials from https://www.etsy.com/developers/your-apps
# Format: keystring:shared_secret
ETSY_API_KEY=
ETSY_DATA_SOURCE=api
ETSY_API_BASE_URL=https://api.etsy.com/v3/application
ETSY_API_TIMEOUT_MS=30000
ETSY_API_MAX_RETRIES=3

HEADLESS=true
DEFAULT_CURRENCY=USD
DEFAULT_COUNTRY=US
DEFAULT_LANGUAGE=en-US

SCRAPER_CONCURRENCY=2
SCRAPER_DELAY_MIN_MS=2500
SCRAPER_DELAY_MAX_MS=6000
SCRAPER_TIMEOUT_MS=45000
SCRAPER_MAX_RETRIES=3

SCRAPE_CACHE_TTL_HOURS=24
CHECKPOINT_INTERVAL=5

API_KEY=
REQUIRE_API_KEY=true
SERVER_HOST=0.0.0.0
TRUST_PROXY=false
CORS_ORIGIN=
RATE_LIMIT_PER_MINUTE=10
MAX_CONCURRENT_JOBS=2
MAX_QUEUED_JOBS=50
MAX_JOBS_RETAINED=100
MAX_REQUEST_BODY_BYTES=16384
SESSION_TTL_DAYS=7

# Docker publishes only on localhost unless this is intentionally changed.
BIND_ADDRESS=127.0.0.1

LOG_LEVEL=info
OUTPUT_DIRECTORY=./data/reports
