{
  "name": "etsy-market-research",
  "version": "1.0.0",
  "description": "Automated market research tool for digital products on Etsy",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "research": "node dist/cli.js",
    "start": "node dist/cli.js",
    "server": "node dist/server.js",
    "dev": "tsx src/cli.ts",
    "dev:server": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "playwright:install": "npx playwright install chromium",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "keywords": [
    "etsy",
    "market-research",
    "scraper",
    "digital-products"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "cheerio": "^1.0.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.7",
    "openai": "^6.46.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.49.1",
    "yargs": "^17.7.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/yargs": "^17.0.33",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.4"
  }
}
